# Copy this to .env and fill in your values
# Never commit .env to source control

# Required: API key from Obsidian Local REST API plugin
OBSIDIAN_API_KEY=your_api_key_here

# Required: URL of the Obsidian Local REST API
# HTTP (default port 27123) — no SSL issues
OBSIDIAN_BASE_URL=http://host.docker.internal:27123

# HTTPS (default port 27124) — set VERIFY_SSL to false for self-signed cert
# OBSIDIAN_BASE_URL=https://host.docker.internal:27124
# OBSIDIAN_VERIFY_SSL=false
